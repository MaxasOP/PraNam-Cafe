        }
        lines {
          text: "    description: \"Flaky, stuffed puris paired with hearty potato sabzi and a side of house chutney. Agra\'s most beloved breakfast.\","
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    veganAlternative: \"Uses robust whole-wheat flour mixed with native spices, fried in clean plant oil. Naturally vegan.\","
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    history: \"Bedhai is a crisp, puffed, lentil-stuffed fried bread unique to Agra. Traditionally eaten at street corners looking towards the rising sun in the early morning streets of the Taj Ganj.\","
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
