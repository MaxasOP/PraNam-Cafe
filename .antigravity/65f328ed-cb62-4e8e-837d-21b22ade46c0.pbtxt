    file_change_type: FILE_CHANGE_TYPE_CREATE
    replacement_chunks {
      replacement_content: "@import url(\'https://fonts.googleapis.com/css2?family=Cinzel:wght@400;500;600;700;800&family=Inter:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;500;600&display=swap\');\n@import \"tailwindcss\";\n\n@theme {\n  --color-brand-blue: #1AACBF;\n  --color-brand-blue-dark: #0D2C33;\n  --color-brand-gold: #B8963E;\n  --color-brand-gold-light: #D4B263;\n  --color-brand-dark: #0B1317;\n  --color-brand-ivory: #FDFBF7;\n  --color-brand-beige: #F4EFE6;\n  --font-serif: \'Cinzel\', serif;\n  --font-sans: \'Inter\', sans-serif;\n  --font-mono: \'JetBrains Mono\', monospace;\n}\n\n@layer utilities {\n  /* Elegant Golden Glassmorphism */\n  .gold-glass {\n    background: rgba(253, 251, 247, 0.85);\n    backdrop-filter: blur(8px);\n    border: 1px solid rgba(184, 150, 62, 0.15);\n  }\n  \n  .dark-glass {\n    background: rgba(11, 19, 23, 0.9);\n    backdrop-filter: blur(12px);\n    border: 1px solid rgba(184, 150, 62, 0.2);\n  }\n\n  /* Custom Scrollbar for premium feeling */\n  ::-webkit-scrollbar {\n    width: 6px;\n    height: 6px;\n  }\n  ::-webkit-scrollbar-track {\n    background: #FDFBF7;\n  }\n  ::-webkit-scrollbar-thumb {\n    background: #B8963E;\n    border-radius: 9px;\n  }\n  ::-webkit-scrollbar-thumb:hover {\n    background: #1AACBF;\n  }\n}\n\n/* Pulsing subtle ambient halo */\n@keyframes gold-glow {\n  0%, 100% {\n    box-shadow: 0 0 10px rgba(184, 150, 62, 0.15);\n  }\n  50% {\n    box-shadow: 0 0 25px rgba(184, 150, 62, 0.4);\n  }\n}\n\n.glow-gold {\n  animation: gold-glow 4s infinite ease-in-out;\n}\n\n/* Steam/ smoke animation for food elements */\n@keyframes steam-drift {\n  0% {\n    transform: translateY(0) scaleX(1) opacity(0);\n  }\n  25% {\n    opacity: 0.4;\n  }\n  50% {\n    transform: translateY(-8px) scaleX(1.1);\n    opacity: 0.6;\n  }\n  80% {\n    opacity: 0.2;\n  }\n  100% {\n    transform: translateY(-16px) scaleX(0.9) opacity(0);\n  }\n}\n\n.animate-steam-1 {\n  animation: steam-drift 3s infinite linear;\n}\n.animate-steam-2 {\n  animation: steam-drift 3.5s infinite linear 1s;\n}\n.animate-steam-3 {\n  animation: steam-drift 4s infinite linear 2s;\n}\n\n/* Sparkle shine animation for the gold letters */\n@keyframes gold-shine {\n  0% { transform: translateX(-100%); }\n  100% { transform: translateX(100%); }\n}\n\n.shine-effect {\n  position: relative;\n  overflow: hidden;\n}\n\n.shine-effect::after {\n  content: \'\';\n  position: absolute;\n  top: 0;\n  left: 0;\n  width: 100%;\n  height: 100%;\n  background: linear-gradient(\n    90deg,\n    transparent,\n    rgba(255, 255, 255, 0.2),\n    transparent\n  );\n  transform: translateX(-100%);\n}\n\n.shine-effect:hover::after {\n  animation: gold-shine 1s forwards;\n}\n"
