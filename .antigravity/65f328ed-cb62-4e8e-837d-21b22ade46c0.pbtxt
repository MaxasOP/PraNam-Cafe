        lines {
          text: "    description: \"Tomatoes transformed through a signature preparation, adorned with the full suite of chaat elements.\","
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    veganAlternative: \"Prepared strictly without ghee. Refined peanut oil is used with vegan-friendly roasted cumin cashew syrup.\","
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    history: \"Exclusively local to Varanasi, this chaat cooks fresh, pulpy tomatoes into a spicy mash served in earthenware bowls (kulhads), seasoned with ginger and a sweet sugar-cumin water.\","
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
