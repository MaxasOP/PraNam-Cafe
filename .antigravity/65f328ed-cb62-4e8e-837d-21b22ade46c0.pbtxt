          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    description: \"Agra\'s iconic petha in syrup \342\200\224 moist, fragrant, glistening. A dessert fit for the Mughal court.\","
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    veganAlternative: \"Naturally vegan. Ash gourd cooked to a plump, juicy sponge state and saturated in high-grade sugar syrup flavored with organic cardamoms.\","
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    history: \"A drippingly sweet variation of the classic petha, traditionally offered to guests at royal courts to express pure hospitality.\","
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
