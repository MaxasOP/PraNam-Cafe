          text: "    category: \"mains\","
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    description: \"Silken moong dal crepe with your choice of paneer, cheese or aloo sabzi. Light, protein-rich, deeply satisfying.\","
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    veganAlternative: \"Uses cold-milled yellow moong flour batter, cooked in mustard oil, stuffed with custom vegan home cheese and garden herbs.\","
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    history: \"A very popular energetic breakfast/snack option across Mathura temples, known for being incredibly gentle on digestion while carrying dense nutrition.\","
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    illustrationSvg: `<svg viewBox=\"0 0 100 100\" class=\"w-full h-full text-green-500 fill-current\">"
