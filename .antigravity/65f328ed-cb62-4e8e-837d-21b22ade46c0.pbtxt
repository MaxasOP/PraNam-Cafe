        lines {
          text: "    category: \"mains\","
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    description: \"Thin, lacy chickpea flour crepe served with fresh paneer or cheese and house chutney.\","
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    veganAlternative: \"Filled with seasoned plant-based shredded tofu cheese, green beans, and roasted almond powder.\","
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    history: \"Mathura is the ancient heartland (Brij Bhoomi) of pastoral food. The besan chilla is a light, protein-filled crepe that honors Brij\'s rustic farm heritage.\","
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
