        }
        lines {
          text: "    category: \"chaat\","
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    description: \"A crisp edible basket filled with spiced potatoes, creamy curd, sweet and tangy chutneys, and crunchy toppings for the perfect mix of textures.\","
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    veganAlternative: \"Crafted with a crispy hand-woven grated potato safe basket, packed with custom plant milk curd, pomegranate jewels, coriander leaves, and spicy sweet tamarind nectar.\","
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    history: \"A visual and gastronomic masterpiece from Hazratganj, Lucknow. It delivers an entire carnival of textures - crunchy, creamy, soft, sweet, tangy, and dangerously spicy - all resting inside a handmade crispy woven potato basket.\","
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    illustrationSvg: `<svg viewBox=\"0 0 100 100\" class=\"w-full h-full text-teal-650 fill-current\">"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
