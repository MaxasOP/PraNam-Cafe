          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    history: \"The absolute standard of comfort food across the Ganges path. The pairing of piping-hot sweet, sour, crispy jalebis with cold, dense, creamy rabdi is a national treasure.\","
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
