        lines {
          text: "    category: \"mains\","
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    description: \"A comforting bowl of spiced chickpea curry paired with fluffy steamed rice.\","
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    veganAlternative: \"Naturally vegan. Prepared with slow-boiled chickpeas simmered in an onion-tomato-pomegranate seed reduction over an open wood-fire.\","
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    history: \"Simple, honest street-corner nourishment that keeps the brass craftsmen of Muradabad energized through intense metalworking shifts.\","
