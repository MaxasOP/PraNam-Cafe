          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    description: \"A protein-rich drink made from roasted gram flour (sattu). Savory, earthy, cooling.\","
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    veganAlternative: \"Naturally 100% vegan. Excellent source of plant-based protein, whisked with cold water, green chillies, and roasted cumin.\","
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    history: \"The rustic superfood of the working class of UP and Bihar. Sattu is roasted black chickpeas ground into fine flour, instantly restoring electrolytes and providing sustainable fiber.\","
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
