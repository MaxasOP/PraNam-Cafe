          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    description: \"The legendary Agra confection \342\200\224 delicate ash gourd candy, crystallised to perfection.\","
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    veganAlternative: \"Naturally 100% vegan. Pure ash gourd (winter melon) boiled down and crystallized in cane sugar syrup with natural kewra (screwpine) essence.\","
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    history: \"Crafted since the construction of the Taj Mahal. Legends say this pure sweet was invented by Shah Jahan\342\200\231s royal chefs to energize the 20,000 workers building the mausoleum.\","
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
